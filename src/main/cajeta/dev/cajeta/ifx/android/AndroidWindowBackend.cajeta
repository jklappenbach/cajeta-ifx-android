package dev.cajeta.ifx.android;

import cajeta.ifx.WindowBackend;
import cajeta.ifx.Window;
import cajeta.ifx.Surface;
import cajeta.ifx.WindowEvent;
import cajeta.ifx.BackendRegistry;

/**
 * AndroidWindowBackend — the Android window/surface backend for ifx, FFI-binding NDK ANativeWindow / GameActivity.
 * Registers itself so the ifx dispatcher can select it on Android. v0.1 skeleton — no FFI yet.
 *
 * Audio (AAudio (+ OpenSL ES fallback)) and input (AInputQueue / GameActivity (touch + gamepad)) backends are sibling classes in this library; see
 * documents/cajeta-ifx-android-plan.md.
 */
public final class AndroidWindowBackend implements WindowBackend {

    /** Called at load to register this backend with ifx. */
    public static void register() {
        BackendRegistry.registerWindow(new AndroidWindowBackend());
    }

    public boolean probe()    { return false; }       // TODO: detect the Android environment
    public int32   priority() { return 100; }
    public String  name()     { return "android"; }

    public Window createWindow(String title, uint32 width, uint32 height) {
        return null;   // TODO: create a window via NDK ANativeWindow / GameActivity
    }

    public Surface surfaceOf(Window w) {
        return null;   // TODO: opaque surface handle for VK_KHR_android_surface
    }

    public WindowEvent[] poll(Window w) {
        return null;   // TODO: drain the Android event queue
    }

    public void destroy(Window w) { }
}
